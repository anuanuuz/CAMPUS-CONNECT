<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Campus Connect</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CampusConnect.styles.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-graduation-cap me-2"></i>Campus Connect
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Dashboard
                            </a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <!-- User Management Module -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarUsers" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-users me-1"></i>Alumni Network
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarUsers">
                                    <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">
                                        <i class="fas fa-search me-1"></i>Browse Alumni
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Users" asp-action="Profile">
                                        <i class="fas fa-user me-1"></i>My Profile
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Users" asp-action="Edit">
                                        <i class="fas fa-edit me-1"></i>Edit Profile
                                    </a></li>
                                </ul>
                            </li>

                            <!-- Event Management Module -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarEvents" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-calendar me-1"></i>Events
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarEvents">
                                    <li><a class="dropdown-item" asp-controller="Events" asp-action="Index">
                                        <i class="fas fa-list me-1"></i>All Events
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Events" asp-action="MyEvents">
                                        <i class="fas fa-calendar-check me-1"></i>My Events
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Events" asp-action="Create">
                                        <i class="fas fa-plus me-1"></i>Create Event
                                    </a></li>
                                </ul>
                            </li>

                            <!-- Networking Module -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarNetworking" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-network-wired me-1"></i>Networking
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarNetworking">
                                    <li><a class="dropdown-item" asp-controller="Jobs" asp-action="Index">
                                        <i class="fas fa-briefcase me-1"></i>Job Board
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Jobs" asp-action="MyJobs">
                                        <i class="fas fa-list-alt me-1"></i>My Job Posts
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Jobs" asp-action="Create">
                                        <i class="fas fa-plus me-1"></i>Post Job
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Messages" asp-action="Inbox">
                                        <i class="fas fa-inbox me-1"></i>Messages
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Messages" asp-action="Compose">
                                        <i class="fas fa-paper-plane me-1"></i>Send Message
                                    </a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-1"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-1"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2024 - Campus Connect - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
