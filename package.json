{
    "name": "alumni-association-laravel",
    "version": "1.0.0",
    "description": "A comprehensive Alumni Association Portal built with Laravel",
    "main": "index.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "watch": "vite build --watch",
        "hot": "vite --host",
        "production": "cross-env NODE_ENV=production vite build",
        "lint": "eslint resources/js --ext .js,.vue",
        "lint:fix": "eslint resources/js --ext .js,.vue --fix",
        "format": "prettier --write resources/js/**/*.{js,vue,css,scss}",
        "test": "jest",
        "test:watch": "jest --watch",
        "analyze": "vite-bundle-analyzer",
        "icons": "npm run icons:optimize && npm run icons:sprite",
        "icons:optimize": "svgo -f resources/icons -o public/icons",
        "icons:sprite": "svg-sprite --config svg-sprite.config.json resources/icons/*.svg"
    },
    "keywords": [
        "laravel",
        "alumni",
        "association",
        "portal",
        "networking",
        "events",
        "education"
    ],
    "author": "Alumni Association Development Team",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/your-organization/alumni-association-laravel.git"
    },
    "bugs": {
        "url": "https://github.com/your-organization/alumni-association-laravel/issues"
    },
    "homepage": "https://github.com/your-organization/alumni-association-laravel#readme",
    "devDependencies": {
        "@vitejs/plugin-vue": "^4.4.0",
        "autoprefixer": "^10.4.16",
        "axios": "^1.6.0",
        "cross-env": "^7.0.3",
        "eslint": "^8.52.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-vue": "^9.17.0",
        "jest": "^29.7.0",
        "laravel-vite-plugin": "^0.8.1",
        "postcss": "^8.4.31",
        "prettier": "^3.0.3",
        "sass": "^1.69.5",
        "svg-sprite": "^2.0.4",
        "svgo": "^3.0.2",
        "tailwindcss": "^3.3.5",
        "vite": "^4.5.0",
        "vite-bundle-analyzer": "^0.7.0",
        "vue": "^3.3.8"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^6.4.2",
        "@popperjs/core": "^2.11.8",
        "alpinejs": "^3.13.2",
        "bootstrap": "^5.3.2",
        "chart.js": "^4.4.0",
        "chartjs-adapter-date-fns": "^3.0.0",
        "date-fns": "^2.30.0",
        "dropzone": "^6.0.0-beta.2",
        "feather-icons": "^4.29.1",
        "fullcalendar": "^6.1.9",
        "gsap": "^3.12.2",
        "inputmask": "^5.0.8",
        "intersectionobserver": "^0.12.2",
        "laravel-echo": "^1.15.3",
        "leaflet": "^1.9.4",
        "lottie-web": "^5.12.2",
        "moment": "^2.29.4",
        "notyf": "^3.10.0",
        "photoswipe": "^5.4.2",
        "pusher-js": "^8.4.0-rc2",
        "quill": "^1.3.7",
        "select2": "^4.1.0-rc.0",
        "sortablejs": "^1.15.0",
        "swiper": "^11.0.4",
        "tippy.js": "^6.3.7",
        "vanilla-lazyload": "^17.8.5"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead",
        "not ie 11"
    ],
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=8.0.0"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "setupFilesAfterEnv": [
            "<rootDir>/tests/jest.setup.js"
        ],
        "moduleNameMapping": {
            "^@/(.*)$": "<rootDir>/resources/js/$1"
        },
        "testMatch": [
            "**/tests/js/**/*.test.js",
            "**/resources/js/**/*.test.js"
        ]
    },
    "prettier": {
        "semi": true,
        "singleQuote": true,
        "tabWidth": 4,
        "trailingComma": "es5",
        "printWidth": 120,
        "bracketSpacing": true,
        "arrowParens": "avoid"
    },
    "eslintConfig": {
        "env": {
            "browser": true,
            "es2021": true,
            "node": true
        },
        "extends": [
            "eslint:recommended",
            "prettier"
        ],
        "parserOptions": {
            "ecmaVersion": 12,
            "sourceType": "module"
        },
        "rules": {
            "no-console": "warn",
            "no-debugger": "error",
            "no-unused-vars": "warn",
            "prefer-const": "error",
            "no-var": "error"
        }
    }
}